# Copie este arquivo para .env.local e preencha os valores reais.
# .env.local NUNCA deve ser commitado (já está no .gitignore).

# ── Pipedrive ──────────────────────────────────────────────────────────────────
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_COMPANY_DOMAIN=suaempresa

# ── Mailchimp ──────────────────────────────────────────────────────────────────
MAILCHIMP_API_KEY=
# O prefixo do servidor (ex: us21) é extraído automaticamente da chave.
# Defina manualmente apenas se a extração automática falhar.
MAILCHIMP_SERVER_PREFIX=
# Preenchido após rodar discover:mailchimp e escolher a audiência alvo.
MAILCHIMP_LIST_ID=

# ── ManyChat ───────────────────────────────────────────────────────────────────
MANYCHAT_API_TOKEN=

# ── Vercel Serverless (api/live-registration.js) ───────────────────────────────
ALLOWED_ORIGIN=https://seu-dominio.vercel.app
CAMPAIGN_ID=live-dia-consultor-2026
